{
  "name": "@cognizant-summer-practice/shared-components",
  "version": "1.0.0",
  "description": "Shared UI components and utilities for Cognizant Summer Practice services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run build:package",
    "build:package": "tsup src/index.ts --format cjs,esm --dts --clean",
    "pack": "npm run build && npm pack",
    "build-and-pack": "node build-and-pack.js",
    "prepare": "npm run build",
    "lint": "echo 'Linting skipped for package build'",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist *.tgz"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@cognizant-summer-practice/shared-components": "file:cognizant-summer-practice-shared-components-1.0.0.tgz",
    "@emailjs/browser": "^4.4.1",
    "@microsoft/signalr": "^8.0.7",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@types/crypto-js": "^4.2.2",
    "@types/react-window": "^1.8.8",
    "antd": "^5.26.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.525.0",
    "next": "15.3.5",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "^1.8.11",
    "recharts": "^2.15.4",
    "stream-chat": "^9.11.0",
    "stream-chat-react": "^13.2.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "peerDependencies": {
    "next": "15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  }
}
